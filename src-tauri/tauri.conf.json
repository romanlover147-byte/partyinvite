{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Party Invite",
  "version": "0.1.0",
  "identifier": "com.party.invite.envelope",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "invite",
        "width": 600,
        "height": 455,
        "resizable": false,
        "fullscreen": false,
        "transparent": false,
        "decorations": true,
        "alwaysOnTop": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
